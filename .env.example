# Базовый путь приложения (для GitHub Pages: /logisticMap/)
VITE_BASE=/

# Публичный OSRM-сервер для построения маршрутов по дорогам
VITE_OSRM_URL=https://router.project-osrm.org/route/v1/driving

# Supabase — общие данные для всех пользователей (создайте проект на supabase.com)
VITE_SUPABASE_URL=https://ВАШ_ПРОЕКТ.supabase.co
VITE_SUPABASE_ANON_KEY=ваш_anon_key

# Логин и пароль — без пароля сайт открыт для всех.
# Задайте оба значения в Netlify/Vercel → Environment variables (не коммитьте в git).
VITE_APP_LOGIN=logist
VITE_APP_PASSWORD=ваш_надёжный_пароль
